# Exemple de configuration (copiez en .env puis adaptez)

# --- Flask ---
SECRET_KEY=change-me

# --- Branding ---
APP_NAME=Élection Nationale
APP_TAGLINE=Simulation • Djibouti
ELECTION_NAME=Élection Nationale 2025

# --- Liens sociaux (optionnel) ---
SOCIAL_FACEBOOK_URL=
SOCIAL_TWITTER_URL=
SOCIAL_LINKEDIN_URL=

# --- Contact / Email (SMTP) ---
# Récepteur final des messages du formulaire /contact
CONTACT_RECIPIENT=your.destination@example.com

# Exemple Gmail (recommandé: mot de passe d'application)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your.gmail@gmail.com
SMTP_PASSWORD=mot-de-passe-application
SMTP_USE_TLS=1
SMTP_USE_SSL=0
SMTP_SENDER=your.gmail@gmail.com
