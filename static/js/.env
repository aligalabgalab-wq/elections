# .env
# Sécurité
SECRET_KEY=votre_clé_secrète_très_longue_et_complexe_à_changer_en_production

# Base de données MySQL (Wampserver)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=election_simulation
DB_USER=root
DB_PASSWORD=

# Application
DEBUG=True
MIN_VOTER_AGE=18
MIN_CANDIDATE_AGE=40
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216

# Admin
# (Les identifiants administrateur ne sont plus définis ici, le compte est
# créé dynamiquement via l'interface d'inscription.)

# Email (optionnel)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=